        ],
        "measures": [
          {
            "name": "Average Age",
            "expression": "AVERAGE(DimPlayer[Age])",
            "lineageTag": "63c0b9d1-b56d-4bac-83fa-fefda4d39e72",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Average Minutes",
            "expression": "AVERAGE(FactPlayerSeason[MinutesPlayed])",
            "lineageTag": "68c1a3b3-f1c0-40d3-ab68-11ab2cdba3f0",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Contribution HTML",
            "expression": [
              "",
              "VAR vTeamGoals = SUM(FactPlayerSeason[Goals])",
              "VAR vTeamAssists = SUM(FactPlayerSeason[Assists])",
              "VAR vTeamTotal = vTeamGoals + vTeamAssists",
              "",
              "VAR vTop5Goals = ",
              "    CALCULATE(",
              "        SUM(FactPlayerSeason[Goals]),",
              "        TOPN(5, VALUES(FactPlayerSeason[PlayerKey]), CALCULATE(SUM(FactPlayerSeason[Goals])), DESC)",
              "    )",
              "VAR vTop5Assists = ",
              "    CALCULATE(",
              "        SUM(FactPlayerSeason[Assists]),",
              "        TOPN(5, VALUES(FactPlayerSeason[PlayerKey]), CALCULATE(SUM(FactPlayerSeason[Assists])), DESC)",
              "    )",
              "VAR vTop5Total = vTop5Goals + vTop5Assists",
              "VAR vTop5Pct = IF(vTeamTotal > 0, DIVIDE(vTop5Total, vTeamTotal, 0), 0)",
              "",
              "VAR vTop10Goals = ",
              "    CALCULATE(",
              "        SUM(FactPlayerSeason[Goals]),",
              "        TOPN(10, VALUES(FactPlayerSeason[PlayerKey]), CALCULATE(SUM(FactPlayerSeason[Goals])), DESC)",
              "    )",
              "VAR vTop10Assists = ",
              "    CALCULATE(",
              "        SUM(FactPlayerSeason[Assists]),",
              "        TOPN(10, VALUES(FactPlayerSeason[PlayerKey]), CALCULATE(SUM(FactPlayerSeason[Assists])), DESC)",
              "    )",
              "VAR vTop10Total = vTop10Goals + vTop10Assists",
              "VAR vTop10Pct = IF(vTeamTotal > 0, DIVIDE(vTop10Total, vTeamTotal, 0), 0)",
              "",
              "VAR vTop5Fmt = IF(ISBLANK(vTop5Pct), \"0%\", FORMAT(vTop5Pct, \"0%\"))",
              "VAR vTop10Fmt = IF(ISBLANK(vTop10Pct), \"0%\", FORMAT(vTop10Pct, \"0%\"))",
              "",
              "RETURN",
              "\"",
              "<style>",
              "  * { box-sizing: border-box; }",
              "  body { margin: 0; padding: 16px; font-family: 'Segoe UI', sans-serif; background: transparent; }",
              "  .contrib-widget { display: flex; flex-direction: column; gap: 12px; }",
              "  .contrib-title { font-size: 14px; font-weight: 600; color: #333; text-align: center; margin-bottom: 4px; }",
              "  .contrib-cards { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; }",
              "  .contrib-card { flex: 1 1 100px; min-width: 80px; max-width: 120px; padding: 14px 10px; border-radius: 10px; text-align: center; box-shadow: 0 2px 6px rgba(0,0,0,0.15); transition: transform 0.2s ease; }",
              "  .contrib-card:hover { transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0,0,0,0.2); }",
              "  .contrib-card.top5 { background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); border-left: 4px solid #2e7d32; }",
              "  .contrib-card.top10 { background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%); border-left: 4px solid #1565c0; }",
              "  .contrib-value { font-size: 22px; font-weight: 700; color: #111; margin-bottom: 4px; }",
              "  .contrib-label { font-size: 11px; color: #555; text-transform: uppercase; letter-spacing: 0.5px; }",
              "</style>",
              "<div class='contrib-widget'>",
              "  <div class='contrib-title'>Top Players Contribution</div>",
              "  <div class='contrib-cards'>",
              "    <div class='contrib-card top5'><div class='contrib-value'>\" & vTop5Fmt & \"</div><div class='contrib-label'>Top 5 (G+A)</div></div>",
              "    <div class='contrib-card top10'><div class='contrib-value'>\" & vTop10Fmt & \"</div><div class='contrib-label'>Top 10 (G+A)</div></div>",
              "  </div>",
              "</div>",
              "\""
            ],
            "lineageTag": "f068da41-25e7-437a-a590-3e4528a563e9"
          },
          {
            "name": "Goals + Assists",
            "expression": "[Total Goals] + [Total Assists]",
            "lineageTag": "e51a2d00-770b-459c-a953-e3cb936f99f0"
          },
          {
            "name": "Performance Score",
            "expression": [
              "",
              "VAR Pos = SELECTEDVALUE(DimPlayer[Position])",
              "VAR G   = SUM(FactPlayerSeason[Goals])",
              "VAR A   = SUM(FactPlayerSeason[Assists])",
              "VAR Sh  = SUM(FactPlayerSeason[Shots])",
              "VAR SoT = SUM(FactPlayerSeason[ShotsOnTarget])",
              "VAR Dr  = SUM(FactPlayerSeason[SuccessfulDribbles])",
              "VAR Int = SUM(FactPlayerSeason[Interceptions])",
              "VAR Tck = SUM(FactPlayerSeason[SuccessfulTackles])",
              "VAR CS  = SUM(FactPlayerSeason[CleanSheets])",
              "VAR Sav = SUM(FactPlayerSeason[Saves])",
              "",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    -- Goalkeeper (1 position)",
              "    Pos = \"Goalkeeper\", (CS * 3) + (Sav / 10),",
              "",
              "    -- Defenders (3): Left back, Right back, Center back",
              "    Pos = \"Left back\",     (Int / 2) + (Tck / 2) + (G * 5) + (A * 3),",
              "    Pos = \"Right back\",    (Int / 2) + (Tck / 2) + (G * 5) + (A * 3),",
              "    Pos = \"Center back\",   (Int / 2) + (Tck / 2) + (G * 5) + (A * 3),",
              "",
              "    -- Midfielders (3): Defensive, Central, Attacking",
              "    Pos = \"Defensive midfielder\", (G * 5) + (A * 3) + (Dr / 5) + (Int / 3) + (Tck / 3),",
              "    Pos = \"Central midfielder\",   (G * 5) + (A * 3) + (Dr / 5) + (Int / 3) + (Tck / 3),",
              "    Pos = \"Attacking midfielder\", (G * 5) + (A * 3) + (Dr / 5) + (Int / 3) + (Tck / 3),",
              "",
              "    -- Forwards / wingers (3): Left winger, Right winger, Forward",
              "    Pos = \"Left winger\",  (G * 5) + (A * 3) + (SoT / 5),",
              "    Pos = \"Right winger\", (G * 5) + (A * 3) + (SoT / 5),",
              "    Pos = \"Forward\",      (G * 5) + (A * 3) + (SoT / 5),",
              "",
              "    -- Fallback (unknown or new position in model)",
              "    (G * 5) + (A * 3)",
              ")"
            ],
            "lineageTag": "c1bd1f89-0de6-44ca-975b-86a0dff986df",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Player Count",
            "expression": "COUNTROWS(DimPlayer)",
            "formatString": "0",
            "lineageTag": "a768b235-a803-4714-83af-eb14e4ba8f06"
          },
          {
            "name": "Players in Bin",
            "expression": [
              "",
              "VAR BinSort = SELECTEDVALUE(MinutesBins[Bin Sort])",
              "VAR Low =",
              "    SWITCH(BinSort, 1, 0, 2, 500, 3, 1000, 4, 1500, 5, 2000, 6, 2500, 7, 3000, 0)",
              "VAR High =",
              "    SWITCH(BinSort, 1, 500, 2, 1000, 3, 1500, 4, 2000, 5, 2500, 6, 3000, 7, 999999, 0)",
              "VAR vTbl =",
              "    FILTER(",
              "        ADDCOLUMNS(VALUES(DimPlayer[PlayerKey]), \"@M\", [Total Minutes]),",
              "        [@M] >= Low && [@M] < High",
              "    )",
              "RETURN",
              "COUNTROWS(vTbl)"
            ],
            "lineageTag": "2dff86e0-c6af-488f-bc78-b573a4d71414"
          },
          {
            "name": "Squad Summary HTML",
            "expression": [
              "",
              "VAR vPlayers = COUNTROWS(FactPlayerSeason)",
              "VAR vGoals = SUM(FactPlayerSeason[Goals])",
              "VAR vAssists = SUM(FactPlayerSeason[Assists])",
              "VAR vAvgAge = AVERAGE(DimPlayer[Age])",
              "",
              "VAR vGoalsFmt = IF(ISBLANK(vGoals) || vGoals = 0, \"0\", FORMAT(vGoals, \"#,0\"))",
              "VAR vAssistsFmt = IF(ISBLANK(vAssists) || vAssists = 0, \"0\", FORMAT(vAssists, \"#,0\"))",
              "VAR vAgeFmt = IF(ISBLANK(vAvgAge), \"–\", FORMAT(vAvgAge, \"0.0\"))",
              "VAR vPlayersFmt = IF(ISBLANK(vPlayers) || vPlayers = 0, \"0\", FORMAT(vPlayers, \"#,0\"))",
              "",
              "RETURN",
              "\"",
              "<style>",
              "  * { box-sizing: border-box; }",
              "  body { margin: 0; padding: 16px; font-family: 'Segoe UI', sans-serif; background: transparent; }",
              "  .squad-summary-widget { display: flex; flex-direction: column; gap: 12px; }",
              "  .squad-summary-title { font-size: 14px; font-weight: 600; color: #333; text-align: center; margin-bottom: 4px; }",
              "  .squad-summary-cards { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; }",
              "  .squad-card { flex: 1 1 100px; min-width: 80px; max-width: 120px; padding: 14px 10px; border-radius: 10px; text-align: center; box-shadow: 0 2px 6px rgba(0,0,0,0.15); transition: transform 0.2s ease; }",
              "  .squad-card:hover { transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0,0,0,0.2); }",
              "  .squad-card.c1 { background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%); border-left: 4px solid #1976d2; }",
              "  .squad-card.c2 { background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%); border-left: 4px solid #388e3c; }",
              "  .squad-card.c3 { background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%); border-left: 4px solid #f57c00; }",
              "  .squad-card.c4 { background: linear-gradient(135deg, #fce4ec 0%, #f8bbd9 100%); border-left: 4px solid #c2185b; }",
              "  .squad-card-value { font-size: 22px; font-weight: 700; color: #111; margin-bottom: 4px; }",
              "  .squad-card-label { font-size: 11px; color: #555; text-transform: uppercase; letter-spacing: 0.5px; }",
              "</style>",
              "<div class='squad-summary-widget'>",
              "  <div class='squad-summary-title'>Squad Summary</div>",
              "  <div class='squad-summary-cards'>",
              "    <div class='squad-card c1'><div class='squad-card-value'>\" & vPlayersFmt & \"</div><div class='squad-card-label'>Players</div></div>",
              "    <div class='squad-card c2'><div class='squad-card-value'>\" & vGoalsFmt & \"</div><div class='squad-card-label'>Goals</div></div>",
              "    <div class='squad-card c3'><div class='squad-card-value'>\" & vAssistsFmt & \"</div><div class='squad-card-label'>Assists</div></div>",
              "    <div class='squad-card c4'><div class='squad-card-value'>\" & vAgeFmt & \"</div><div class='squad-card-label'>Avg Age</div></div>",
              "  </div>",
              "</div>",
              "\""
            ],
