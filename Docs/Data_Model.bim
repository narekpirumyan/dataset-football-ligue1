                "    #\"Requêtes fusionnées\" = Table.NestedJoin(Source, {\"player_id\"}, DimPlayer, {\"PlayerId\"}, \"DimPlayer\", JoinKind.LeftOuter),",
                "    #\"DimPlayer développé\" = Table.ExpandTableColumn(#\"Requêtes fusionnées\", \"DimPlayer\", {\"PlayerKey\"}, {\"DimPlayer.PlayerKey\"}),",
                "    #\"Colonnes renommées\" = Table.RenameColumns(#\"DimPlayer développé\",{{\"DimPlayer.PlayerKey\", \"PlayerKey\"}}),",
                "    #\"Requêtes fusionnées1\" = Table.NestedJoin(#\"Colonnes renommées\", {\"departure_club\"}, DimClub, {\"ClubName\"}, \"DimClub\", JoinKind.LeftOuter),",
                "    #\"DimClub développé\" = Table.ExpandTableColumn(#\"Requêtes fusionnées1\", \"DimClub\", {\"ClubKey\"}, {\"DimClub.ClubKey\"}),",
                "    #\"Colonnes renommées1\" = Table.RenameColumns(#\"DimClub développé\",{{\"DimClub.ClubKey\", \"DepartureClubKey\"}}),",
                "    #\"Requêtes fusionnées2\" = Table.NestedJoin(#\"Colonnes renommées1\", {\"arrival_club\"}, DimClub, {\"ClubName\"}, \"DimClub\", JoinKind.LeftOuter),",
                "    #\"DimClub développé1\" = Table.ExpandTableColumn(#\"Requêtes fusionnées2\", \"DimClub\", {\"ClubKey\"}, {\"DimClub.ClubKey\"}),",
                "    #\"Colonnes renommées2\" = Table.RenameColumns(#\"DimClub développé1\",{{\"DimClub.ClubKey\", \"ArrivalClubKey\"}}),",
                "    #\"Requêtes fusionnées3\" = Table.NestedJoin(#\"Colonnes renommées2\", {\"transfer_date\"}, DimDate, {\"DateKey\"}, \"DimDate\", JoinKind.LeftOuter),",
                "    #\"DimDate développé\" = Table.ExpandTableColumn(#\"Requêtes fusionnées3\", \"DimDate\", {\"DateKey\"}, {\"DimDate.DateKey\"}),",
                "    #\"Colonnes renommées3\" = Table.RenameColumns(#\"DimDate développé\",{{\"DimDate.DateKey\", \"TransferDateKey\"}, {\"transfer_id\", \"TransferKey\"}}),",
                "    #\"Colonnes permutées\" = Table.ReorderColumns(#\"Colonnes renommées3\",{\"TransferKey\", \"PlayerKey\", \"player\", \"player_id\", \"departure_club\", \"arrival_club\", \"transfer_type\", \"amount_ME\", \"transfer_date\", \"agent\", \"DepartureClubKey\", \"ArrivalClubKey\", \"TransferDateKey\"}),",
                "    #\"Colonnes supprimées\" = Table.RemoveColumns(#\"Colonnes permutées\",{\"player\", \"player_id\", \"arrival_club\"}),",
