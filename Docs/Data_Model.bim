        "name": "StandingsFinal",
        "lineageTag": "aecdc510-652e-4be4-9ec9-4365bf404c98",
        "columns": [
          {
            "type": "calculatedTableColumn",
            "name": "ClubKey",
            "dataType": "int64",
            "isNameInferred": true,
            "isDataTypeInferred": true,
            "sourceColumn": "DimClub[ClubKey]",
            "formatString": "0",
            "lineageTag": "94dfbb6d-4fbe-4f68-a315-dbd8efa1c227",
            "summarizeBy": "count",
            "annotations": [
              {
                "name": "SummarizationSetBy",
