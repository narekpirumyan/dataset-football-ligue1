            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Staging_Sanctions,",
                "    #\"Colonnes supprimées\" = Table.RemoveColumns(Source,{\"player\"}),",
                "    #\"Colonnes renommées\" = Table.RenameColumns(#\"Colonnes supprimées\",{{\"sanction_id\", \"SanctionKey\"}}),",
                "    #\"Requêtes fusionnées\" = Table.NestedJoin(#\"Colonnes renommées\", {\"player_id\"}, DimPlayer, {\"PlayerId\"}, \"DimPlayer\", JoinKind.LeftOuter),",
                "    #\"DimPlayer développé\" = Table.ExpandTableColumn(#\"Requêtes fusionnées\", \"DimPlayer\", {\"PlayerKey\"}, {\"DimPlayer.PlayerKey\"}),",
                "    #\"Colonnes renommées1\" = Table.RenameColumns(#\"DimPlayer développé\",{{\"DimPlayer.PlayerKey\", \"PlayerKey\"}}),",
                "    #\"Colonnes permutées\" = Table.ReorderColumns(#\"Colonnes renommées1\",{\"SanctionKey\", \"PlayerKey\", \"player_id\", \"club\", \"sanction_date\", \"sanction_type\", \"reason\", \"suspension_matches\", \"fine_euros\"}),",
                "    #\"Colonnes supprimées1\" = Table.RemoveColumns(#\"Colonnes permutées\",{\"player_id\"}),",
                "    #\"Requêtes fusionnées1\" = Table.NestedJoin(#\"Colonnes supprimées1\", {\"club\"}, DimClub, {\"ClubName\"}, \"DimClub\", JoinKind.LeftOuter),",
                "    #\"DimClub développé\" = Table.ExpandTableColumn(#\"Requêtes fusionnées1\", \"DimClub\", {\"ClubKey\"}, {\"DimClub.ClubKey\"}),",
                "    #\"Colonnes renommées2\" = Table.RenameColumns(#\"DimClub développé\",{{\"DimClub.ClubKey\", \"ClubKey\"}}),",
                "    #\"Colonnes permutées1\" = Table.ReorderColumns(#\"Colonnes renommées2\",{\"SanctionKey\", \"PlayerKey\", \"ClubKey\", \"club\", \"sanction_date\", \"sanction_type\", \"reason\", \"suspension_matches\", \"fine_euros\"}),",
                "    #\"Colonnes supprimées2\" = Table.RemoveColumns(#\"Colonnes permutées1\",{\"club\"}),",
                "    #\"Requêtes fusionnées2\" = Table.NestedJoin(#\"Colonnes supprimées2\", {\"sanction_date\"}, DimDate, {\"DateKey\"}, \"DimDate\", JoinKind.LeftOuter),",
                "    #\"DimDate développé\" = Table.ExpandTableColumn(#\"Requêtes fusionnées2\", \"DimDate\", {\"DateKey\"}, {\"DimDate.DateKey\"}),",
                "    #\"Colonnes renommées3\" = Table.RenameColumns(#\"DimDate développé\",{{\"DimDate.DateKey\", \"SanctionDateKey\"}}),",
                "    #\"Colonnes permutées2\" = Table.ReorderColumns(#\"Colonnes renommées3\",{\"SanctionKey\", \"PlayerKey\", \"ClubKey\", \"SanctionDateKey\", \"sanction_date\", \"sanction_type\", \"reason\", \"suspension_matches\", \"fine_euros\"}),",
                "    #\"Colonnes supprimées3\" = Table.RemoveColumns(#\"Colonnes permutées2\",{\"sanction_date\"}),",
                "    #\"Colonnes renommées4\" = Table.RenameColumns(#\"Colonnes supprimées3\",{{\"sanction_type\", \"SanctionType\"}, {\"reason\", \"Reason\"}, {\"suspension_matches\", \"SuspensionMatches\"}, {\"fine_euros\", \"FineEuros\"}})",
                "in",
