                "    #\"En-têtes promus\" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    #\"Type modifié\" = Table.TransformColumnTypes(#\"En-têtes promus\",{{\"transfer_id\", type text}, {\"player\", type text}, {\"player_id\", type text}, {\"departure_club\", type text}, {\"arrival_club\", type text}, {\"transfer_type\", type text}, {\"amount_ME\", type text}, {\"transfer_date\", type date}, {\"agent\", type text}}),",
                "    #\"Doublons supprimés\" = Table.Distinct(#\"Type modifié\", {\"transfer_id\"}),",
                "    #\"Espaces supprimés\" = Table.TransformColumns(#\"Doublons supprimés\",{{\"player\", Text.Trim, type text}, {\"player_id\", Text.Trim, type text}, {\"departure_club\", Text.Trim, type text}, {\"arrival_club\", Text.Trim, type text}, {\"transfer_type\", Text.Trim, type text}, {\"amount_ME\", Text.Trim, type text}, {\"agent\", Text.Trim, type text}}),",
                "    #\"Personnalisée ajoutée\" = Table.AddColumn(#\"Espaces supprimés\", \"AmountMEFixed\", each let",
                "  raw = Text.Trim(Text.From([amount_ME])),",
                "  removeMEuro = Text.Replace(raw, \"M€\", \"\"),",
                "  removeSpaceM = Text.Replace(removeMEuro, \" M\", \"\"),",
                "  removeM = Text.Replace(removeSpaceM, \"M\", \"\"),",
                "  removeSpaces = Text.Replace(removeM, \" \", \"\"),",
                "  result = if removeSpaces = \"\" or removeSpaces = null then 0 else Number.FromText(removeSpaces)",
                "in result),",
                "    #\"Type modifié1\" = Table.TransformColumnTypes(#\"Personnalisée ajoutée\",{{\"AmountMEFixed\", type number}}),",
                "    #\"Colonnes permutées\" = Table.ReorderColumns(#\"Type modifié1\",{\"transfer_id\", \"player\", \"player_id\", \"departure_club\", \"arrival_club\", \"transfer_type\", \"amount_ME\", \"AmountMEFixed\", \"transfer_date\", \"agent\"}),",
