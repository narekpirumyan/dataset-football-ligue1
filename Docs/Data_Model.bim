                "    #\"Colonnes renommées\" = Table.RenameColumns(#\"Colonnes supprimées\",{{\"AmountMEFixed\", \"amount_ME\"}})",
                "in",
                "    #\"Colonnes renommées\""
              ]
            }
          }
        ],
