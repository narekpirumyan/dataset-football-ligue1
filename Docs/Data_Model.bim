        "partitions": [
          {
            "name": "RivalryPair",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": [
                "",
                "ADDCOLUMNS(",
                "    SUMMARIZE(DimMatch, DimMatch[HomeClubKey], DimMatch[AwayClubKey]),",
                "    \"PairLabel\",",
                "        LOOKUPVALUE(DimClub[ClubName], DimClub[ClubKey], [HomeClubKey])",
                "            & \" – \" & LOOKUPVALUE(DimClub[ClubName], DimClub[ClubKey], [AwayClubKey])",
                ")"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Total Goals in Rivalry",
            "expression": [
              "",
              "CALCULATE(SUM(FactClubMatch[GoalsFor]),",
              "    FILTER(DimMatch,",
              "        DimMatch[HomeClubKey] = MAX(RivalryPair[HomeClubKey])",
              "            && DimMatch[AwayClubKey] = MAX(RivalryPair[AwayClubKey])))"
            ],
            "formatString": "0",
            "lineageTag": "e6a3ca88-365f-4112-845e-ac33d1e6b0b0"
          },
          {
            "name": "Avg Attendance in Rivalry",
            "expression": "CALCULATE(AVERAGE(DimMatch[Attendance]), FILTER(DimMatch, DimMatch[HomeClubKey] = MAX(RivalryPair[HomeClubKey]) && DimMatch[AwayClubKey] = MAX(RivalryPair[AwayClubKey])))",
            "lineageTag": "c68d1e31-ab53-43c8-994d-194dda9ef0cb",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Avg Fill Rate in Rivalry",
            "expression": [
              "",
              "VAR HomeK = MAX(RivalryPair[HomeClubKey])",
              "VAR AwayK = MAX(RivalryPair[AwayClubKey])",
              "RETURN",
              "    CALCULATE(",
              "        AVERAGE(FactAttendance[FillRatePct]),",
              "        FILTER(DimMatch,",
              "            DimMatch[HomeClubKey] = HomeK && DimMatch[AwayClubKey] = AwayK),",
              "        REMOVEFILTERS(DimClub)",
              "    )"
            ],
            "formatString": "0",
            "lineageTag": "236fbccd-a455-4729-89da-0c9102f8477b"
          }
        ],
        "annotations": [
          {
            "name": "PBI_Id",
            "value": "a3416360a676479db6da3423622b5c32"
          }
        ]
      },
