        "partitions": [
          {
            "name": "Staging_MatchResults",
            "mode": "import",
            "queryGroup": "Staging Queries",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(\"C:\\Users\\frede\\Downloads\\match_results_2023_2024.csv\"),[Delimiter=\",\", Columns=10, Encoding=1252, QuoteStyle=QuoteStyle.None]),",
                "    #\"En-têtes promus\" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    #\"Type modifié\" = Table.TransformColumnTypes(#\"En-têtes promus\",{{\"match_id\", type text}, {\"matchday\", Int64.Type}, {\"match_date\", type text}, {\"home_team\", type text}, {\"away_team\", type text}, {\"home_score\", Int64.Type}, {\"away_score\", Int64.Type}, {\"stadium\", type text}, {\"referee\", type text}, {\"attendance\", Int64.Type}}),",
                "    #\"Espaces supprimés\" = Table.TransformColumns(#\"Type modifié\",{{\"match_date\", Text.Trim, type text}, {\"home_team\", Text.Trim, type text}, {\"away_team\", Text.Trim, type text}, {\"match_id\", Text.Trim, type text}, {\"stadium\", Text.Trim, type text}, {\"referee\", Text.Trim, type text}}),",
                "    #\"Personnalisée ajoutée\" = Table.AddColumn(#\"Espaces supprimés\", \"MatchDateFixed\", each let",
                "  raw = Text.Trim(Text.From([match_date])),",
                "  tryIso = try Date.FromText(raw) otherwise null,",
                "  trySlash = if tryIso = null then try Date.FromText(Text.Replace(raw, \"/\", \"-\")) otherwise tryIso else tryIso,",
                "  tryDayMonth = if trySlash = null then try Date.From(DateTime.FromText(raw)) otherwise trySlash else trySlash,",
                "  tryDdMmYyyy = if tryDayMonth = null and Text.Contains(raw, \"/\") then",
                "    let",
                "      parts = Text.Split(raw, \"/\"),",
                "      day = Number.FromText(parts{0}),",
                "      month = Number.FromText(parts{1}),",
                "      year = Number.FromText(parts{2})",
                "    in",
                "      #date(year, month, day)",
                "    else tryDayMonth",
                "in tryDdMmYyyy),",
                "    #\"Type modifié1\" = Table.TransformColumnTypes(#\"Personnalisée ajoutée\",{{\"MatchDateFixed\", type date}}),",
                "    #\"Colonnes supprimées\" = Table.RemoveColumns(#\"Type modifié1\",{\"match_date\"}),",
                "    #\"Colonnes renommées\" = Table.RenameColumns(#\"Colonnes supprimées\",{{\"MatchDateFixed\", \"match_date\"}}),",
                "    #\"Type modifié2\" = Table.TransformColumnTypes(#\"Colonnes renommées\",{{\"matchday\", Int64.Type}, {\"home_score\", Int64.Type}, {\"away_score\", Int64.Type}, {\"attendance\", Int64.Type}}),",
                "    #\"Lignes filtrées\" = Table.SelectRows(#\"Type modifié2\", each true),",
                "    #\"Doublons supprimés\" = Table.Distinct(#\"Lignes filtrées\", {\"match_id\"})",
                "in",
                "    #\"Doublons supprimés\""
              ]
            }
          }
        ],
