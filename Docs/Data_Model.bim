          },
          {
            "type": "calculatedTableColumn",
            "name": "@FinalPoints",
            "dataType": "int64",
            "isNameInferred": true,
            "isDataTypeInferred": true,
            "sourceColumn": "[@FinalPoints]",
            "formatString": "0",
            "lineageTag": "151eb27b-d24b-4378-997a-ae9d9a0551a8",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculatedTableColumn",
            "name": "FinalRank",
            "dataType": "int64",
            "isNameInferred": true,
            "isDataTypeInferred": true,
            "sourceColumn": "[FinalRank]",
            "formatString": "0",
            "lineageTag": "85e34f89-7e7e-4da2-a315-84b35e1ba5e8",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          }
        ],
        "partitions": [
          {
            "name": "StandingsFinal",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": [
                "",
                "VAR ClubsWithPoints = ",
                "    ADDCOLUMNS(",
                "        ALL(DimClub[ClubKey]),",
                "        \"@FinalPoints\",",
                "        CALCULATE(",
                "            SUM(FactClubMatch[Points]),",
                "            DimMatch[Matchday] = 38",
                "        )",
                "    )",
                "RETURN",
                "    ADDCOLUMNS(",
                "        ClubsWithPoints,",
                "        \"FinalRank\",",
                "        RANKX(ClubsWithPoints, [@FinalPoints], [@FinalPoints], DESC, Dense)",
                "    )"
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_Id",
            "value": "54b940bbd7174e0582982298f3716753"
          }
        ]
      },
      {
        "name": "MinutesBins",
