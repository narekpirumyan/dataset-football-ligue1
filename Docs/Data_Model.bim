              }
            ]
          },
          {
            "type": "calculatedTableColumn",
            "name": "Min",
            "dataType": "int64",
            "isNameInferred": true,
            "isDataTypeInferred": true,
            "sourceColumn": "[Min]",
            "formatString": "0",
            "lineageTag": "32d0d9c3-7a5a-4a41-8d4a-f572493a6ac3",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculatedTableColumn",
            "name": "Max",
            "dataType": "int64",
            "isNameInferred": true,
            "isDataTypeInferred": true,
            "sourceColumn": "[Max]",
            "formatString": "0",
            "lineageTag": "fcea7a47-d6d2-478a-9f39-dd45469ffda8",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculatedTableColumn",
            "name": "Label",
            "dataType": "string",
            "isNameInferred": true,
            "isDataTypeInferred": true,
            "sourceColumn": "[Label]",
            "lineageTag": "09c703a2-d94f-47fa-88b6-9630dcbe0665",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "type": "calculatedTableColumn",
            "name": "Sort",
            "dataType": "int64",
            "isNameInferred": true,
            "isDataTypeInferred": true,
            "sourceColumn": "[Sort]",
            "formatString": "0",
            "lineageTag": "54281ed8-7193-4437-a127-06b186d62004",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          }
        ],
        "partitions": [
          {
            "name": "FillRate Bins",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": [
                "",
                "VAR Step = 5",
                "RETURN",
                "ADDCOLUMNS (",
                "    GENERATESERIES ( 0, 100, Step ),",
                "    \"Min\", [Value],",
                "    \"Max\", [Value] + Step,",
                "    \"Label\", FORMAT ( [Value], \"0\" ) & \"% – \" & FORMAT ( [Value] + Step, \"0\" ) & \"%\",",
                "    \"Sort\", [Value]",
                ")"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Sanctions by FillRate Bin",
            "expression": [
              "",
              "VAR MinBin = SELECTEDVALUE ( 'FillRate Bins'[Min] )",
              "VAR MaxBin = SELECTEDVALUE ( 'FillRate Bins'[Max] )",
              "VAR AttendanceInBin =",
              "    FILTER (",
              "        ALL ( FactAttendance ),",
              "        FactAttendance[FillRatePct] >= MinBin",
              "            && FactAttendance[FillRatePct] < MaxBin",
              "    )",
              "VAR Keys =",
              "    SELECTCOLUMNS (",
              "        AttendanceInBin,",
              "        \"ClubKey\", FactAttendance[ClubKey],",
              "        \"SanctionDateKey\", FactAttendance[DateKey]",
              "    )",
              "RETURN",
              "    CALCULATE (",
              "        COUNTROWS ( FactSanction ),",
              "        TREATAS ( Keys, FactSanction[ClubKey], FactSanction[SanctionDateKey] )",
              "    )"
            ],
            "formatString": "0",
            "lineageTag": "704ea6d0-1d2b-4a50-8288-d13dcbd06d1f"
          }
        ],
        "annotations": [
          {
            "name": "PBI_Id",
            "value": "a9c351d607a14fd5a4e86a7caa6a1427"
          }
        ]
      },
      {
        "name": "KPIs Player",
        "lineageTag": "b65b825a-92e1-458b-859d-3331a559aa8a",
        "columns": [
          {
            "type": "calculatedTableColumn",
            "name": "Column",
            "dataType": "int64",
            "isNameInferred": true,
            "isDataTypeInferred": true,
            "sourceColumn": "[Column]",
            "formatString": "0",
            "lineageTag": "746e6427-e68b-425b-9641-d6354d5fdec1",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          }
        ],
        "partitions": [
          {
            "name": "KPIs Player",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": "Row(\"Column\", BLANK())"
            }
          }
        ],
        "measures": [
          {
            "name": "Goals KPI HTML",
            "expression": [
              "",
              "VAR vPlayer = SUM(FactPlayerSeason[Goals])",
              "VAR vAvg = CALCULATE(AVERAGE(FactPlayerSeason[Goals]), ALLEXCEPT(DimPlayer, DimPlayer[Position]))",
              "VAR vMin = CALCULATE(MIN(FactPlayerSeason[Goals]), ALLEXCEPT(DimPlayer, DimPlayer[Position]))",
              "VAR vMax = CALCULATE(MAX(FactPlayerSeason[Goals]), ALLEXCEPT(DimPlayer, DimPlayer[Position]))",
              "",
              "VAR vPlayerFmt = IF(ISBLANK(vPlayer) || vPlayer = 0, \"0\", FORMAT(vPlayer, \"#,0\"))",
              "VAR vAvgFmt = IF(ISBLANK(vAvg), \"–\", FORMAT(vAvg, \"#,0\"))",
              "VAR vMinFmt = IF(ISBLANK(vMin), \"–\", FORMAT(vMin, \"#,0\"))",
              "VAR vMaxFmt = IF(ISBLANK(vMax), \"–\", FORMAT(vMax, \"#,0\"))",
              "",
              "VAR vRange = vMax - vMin",
              "VAR vAvgPct = IF(vRange <= 0, 0.5, DIVIDE(vAvg - vMin, vRange, 0.5))",
              "VAR vAvgX = ROUND(12 + 176 * vAvgPct, 0)",
              "",
              "RETURN",
              "\"",
              "<style>",
              "  * { box-sizing: border-box; }",
              "  .gauge-goals { font-family: 'Segoe UI', sans-serif; background: #fff; padding: 14px; border-radius: 10px; text-align: center; width: 200px; }",
              "  .gauge-goals .gauge-icon { font-size: 22px; margin-bottom: 2px; display: block; }",
              "  .gauge-goals .gauge-label { font-size: 11px; color: #444; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; display: block; }",
              "  .gauge-goals .gauge-svg-wrap { display: block; width: 200px; height: 70px; margin: 0 auto 8px auto; }",
              "  .gauge-goals .gauge-scale-row { display: flex; justify-content: space-between; width: 200px; margin: 0 auto 10px auto; font-size: 11px; color: #666; font-weight: 600; }",
              "  .gauge-goals .gauge-value { font-size: 32px; font-weight: 700; color: #1a1a1a; display: block; margin-bottom: 4px; }",
              "  .gauge-goals .gauge-moy { font-size: 11px; color: #666; }",
              "</style>",
              "<div class='gauge-goals'>",
              "  <span class='gauge-icon'>⚽</span>",
              "  <span class='gauge-label'>Buts</span>",
              "  <span class='gauge-svg-wrap'>",
              "    <svg viewBox='0 0 200 110' width='200' height='70' preserveAspectRatio='xMidYMid meet'>",
              "      <path d='M 12 88 A 88 88 0 0 0 188 88' fill='none' stroke='#1565C0' stroke-width='12' stroke-linecap='round'/>",
              "      <line x1='\" & vAvgX & \"' y1='88' x2='\" & vAvgX & \"' y2='70' stroke='#0D47A1' stroke-width='2.5' stroke-linecap='round'/>",
              "    </svg>",
              "  </span>",
              "  <div class='gauge-scale-row'><span>\" & vMinFmt & \"</span><span>\" & vMaxFmt & \"</span></div>",
              "  <span class='gauge-value'>\" & vPlayerFmt & \"</span>",
              "  <span class='gauge-moy'>Moy. poste \" & vAvgFmt & \"</span>",
              "</div>",
              "\""
            ],
            "lineageTag": "74a018e3-d99f-4536-a033-83dde721a1e0"
          }
        ],
