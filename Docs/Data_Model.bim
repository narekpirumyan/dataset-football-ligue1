            "sourceColumn": "[Bin Label]",
            "lineageTag": "588f348c-cdb0-4d4f-8bc0-1449ba76cab9",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          }
        ],
        "partitions": [
          {
            "name": "MinutesBins",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": [
                "",
                "DATATABLE(",
                "    \"Bin Sort\", INTEGER,",
                "    \"Bin Label\", STRING,",
                "    {",
                "        {1, \"0-500\"},",
                "        {2, \"500-1K\"},",
                "        {3, \"1K-1.5K\"},",
                "        {4, \"1.5K-2K\"},",
                "        {5, \"2K-2.5K\"},",
                "        {6, \"2.5K-3K\"},",
                "        {7, \"3K+\"}",
                "    }",
                ")"
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "PBI_Id",
            "value": "46a0cdbe5cc5420b9099430d0bea46ff"
          }
        ]
      },
      {
        "name": "FillRate Bins",
        "lineageTag": "6fde2fb4-cfdf-4010-af9e-37b884e24e8e",
        "columns": [
          {
            "type": "calculatedTableColumn",
            "name": "Value",
            "dataType": "int64",
            "isNameInferred": true,
            "isDataTypeInferred": true,
            "sourceColumn": "[Value]",
            "formatString": "0",
            "lineageTag": "cdd04b87-4909-4610-9261-86c93f8fa223",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
