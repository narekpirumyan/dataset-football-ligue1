        ],
        "measures": [
          {
            "name": "Sanction Count",
            "expression": "COUNTROWS(FactSanction)",
            "formatString": "0",
            "lineageTag": "190fb9e4-8ea6-46a6-9dcf-02d16c416c2c"
          },
          {
            "name": "Cumulative Sanction Count",
            "expression": [
              "",
              "VAR CurrentMatchday =",
              "    MAX ( DimMatch[Matchday] )",
              "VAR EndDate =",
              "    CALCULATE (",
              "        MAX ( DimMatch[DateKey] ),",
              "        REMOVEFILTERS ( DimMatch ),",
              "        DimMatch[Matchday] = CurrentMatchday",
              "    )",
              "RETURN",
              "    CALCULATE (",
              "        [Sanction Count],",
              "        REMOVEFILTERS ( DimMatch ),            -- clé: enlever le filtre de l’axe",
              "        FILTER (",
              "            ALL ( DimDate[DateKey] ),          -- cumul via la dimension date",
              "            DimDate[DateKey] <= EndDate",
              "        )",
              "    )"
            ],
            "formatString": "0",
            "lineageTag": "c881e647-aa50-4f83-abe8-ea01014b5533"
          },
          {
            "name": "Sanctions Domicile",
            "expression": [
              "",
              "SUMX(",
              "    FILTER(",
              "        FactSanction,",
              "        FactSanction[Reason] = \"Abusive language in mixed zone\"",
              "            || FactSanction[Reason] = \"Accumulation of yellow cards\"",
              "            || FactSanction[Reason] = \"Deliberate elbow strike\"",
              "            || FactSanction[Reason] = \"Inappropriate gesture towards an opponent\"",
              "            || FactSanction[Reason] = \"Insulting the referee\"",
              "            || FactSanction[Reason] = \"On-field brawl\"",
              "            || FactSanction[Reason] = \"Red card - last man foul\"",
              "            || FactSanction[Reason] = \"Repeated protesting\"",
              "            || FactSanction[Reason] = \"Simulation\"",
              "            || FactSanction[Reason] = \"Spitting\"",
              "            || FactSanction[Reason] = \"Straight red card - dangerous tackle\"",
              "            || FactSanction[Reason] = \"Unsportsmanlike conduct\"",
              "    ),",
              "    VAR LastMatchDate =",
              "        CALCULATE(",
              "            MAX(DimMatch[DateKey]),",
              "            FILTER(",
              "                DimMatch,",
              "                DimMatch[DateKey] <= FactSanction[SanctionDateKey]",
              "                    && (DimMatch[HomeClubKey] = FactSanction[ClubKey]",
              "                        || DimMatch[AwayClubKey] = FactSanction[ClubKey])",
              "            )",
              "        )",
              "    VAR IsHome =",
              "        NOT ISBLANK(LastMatchDate)",
              "        && COUNTROWS(",
              "            FILTER(",
              "                DimMatch,",
              "                DimMatch[DateKey] = LastMatchDate",
              "                    && DimMatch[HomeClubKey] = FactSanction[ClubKey]",
              "            )",
              "        ) > 0",
              "    RETURN IF(IsHome, 1, 0)",
              ")",
              ""
            ],
            "formatString": "0",
            "lineageTag": "390983e6-3753-4ad2-af90-2d0d61f4e5dd"
          },
          {
            "name": "Sanctions Extérieur",
            "expression": [
              "",
              "SUMX(",
              "    FILTER(",
              "        FactSanction,",
              "        FactSanction[Reason] = \"Abusive language in mixed zone\"",
              "            || FactSanction[Reason] = \"Accumulation of yellow cards\"",
              "            || FactSanction[Reason] = \"Deliberate elbow strike\"",
              "            || FactSanction[Reason] = \"Inappropriate gesture towards an opponent\"",
              "            || FactSanction[Reason] = \"Insulting the referee\"",
              "            || FactSanction[Reason] = \"On-field brawl\"",
              "            || FactSanction[Reason] = \"Red card - last man foul\"",
              "            || FactSanction[Reason] = \"Repeated protesting\"",
              "            || FactSanction[Reason] = \"Simulation\"",
              "            || FactSanction[Reason] = \"Spitting\"",
              "            || FactSanction[Reason] = \"Straight red card - dangerous tackle\"",
              "            || FactSanction[Reason] = \"Unsportsmanlike conduct\"",
              "    ),",
              "    VAR LastMatchDate =",
              "        CALCULATE(",
              "            MAX(DimMatch[DateKey]),",
              "            FILTER(",
              "                DimMatch,",
              "                DimMatch[DateKey] <= FactSanction[SanctionDateKey]",
              "                    && (DimMatch[HomeClubKey] = FactSanction[ClubKey]",
              "                        || DimMatch[AwayClubKey] = FactSanction[ClubKey])",
              "            )",
              "        )",
              "    VAR IsAway =",
              "        NOT ISBLANK(LastMatchDate)",
              "        && COUNTROWS(",
              "            FILTER(",
              "                DimMatch,",
              "                DimMatch[DateKey] = LastMatchDate",
              "                    && DimMatch[AwayClubKey] = FactSanction[ClubKey]",
              "            )",
              "        ) > 0",
              "    RETURN IF(IsAway, 1, 0)",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "494fd6b6-43a6-4529-ae6e-d80f92a9ad62"
          }
        ],
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
