        ],
        "partitions": [
          {
            "name": "DimClub",
            "mode": "import",
            "queryGroup": "Dimensions",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    // 1. Ligue 1 clubs from Staging_Clubs (your logic + External = false)",
                "    Source = Staging_Clubs,",
                "    AddedIndex = Table.AddIndexColumn(Source, \"ClubKey\", 0, 1, Int64.Type),",
                "    Reordered = Table.ReorderColumns(AddedIndex, {\"ClubKey\", \"club_id\", \"club_name\", \"city\", \"stadium\", \"capacity\", \"founded\", \"president\", \"coach\", \"budget_ME\", \"colors\"}),",
                "    RenamedClubName = Table.RenameColumns(Reordered, {{\"club_name\", \"ClubName\"}}),",
                "    DistinctClubId = Table.Distinct(RenamedClubName, {\"club_id\"}),",
                "    Ligue1Clubs = Table.AddColumn(DistinctClubId, \"External\", each false, type logical),",
                "",
                "    // 2. All distinct club names from other sources",
                "    HomeClubs = Table.RenameColumns(Table.SelectColumns(Staging_MatchResults, {\"home_team\"}), {{\"home_team\", \"ClubName\"}}),",
                "    AwayClubs = Table.RenameColumns(Table.SelectColumns(Staging_MatchResults, {\"away_team\"}), {{\"away_team\", \"ClubName\"}}),",
                "    PlayerStatsClubs = Table.RenameColumns(Table.SelectColumns(Staging_PlayerStats, {\"club\"}), {{\"club\", \"ClubName\"}}),",
                "    TransfersDep = Table.RenameColumns(Table.SelectColumns(Staging_Transfers, {\"departure_club\"}), {{\"departure_club\", \"ClubName\"}}),",
                "    TransfersArr = Table.RenameColumns(Table.SelectColumns(Staging_Transfers, {\"arrival_club\"}), {{\"arrival_club\", \"ClubName\"}}),",
                "    StadiumClubs = Table.RenameColumns(Table.SelectColumns(Staging_StadiumAttendance, {\"club\"}), {{\"club\", \"ClubName\"}}),",
                "    SanctionsClubs = Table.RenameColumns(Table.SelectColumns(Staging_Sanctions, {\"club\"}), {{\"club\", \"ClubName\"}}),",
                "    CombinedNames = Table.Combine({HomeClubs, AwayClubs, PlayerStatsClubs, TransfersDep, TransfersArr, StadiumClubs, SanctionsClubs}),",
                "    TrimmedNames = Table.TransformColumns(CombinedNames, {{\"ClubName\", Text.Trim, type text}}),",
                "    DistinctNames = Table.Distinct(TrimmedNames, {\"ClubName\"}),",
                "",
                "    // 3. Keep only names NOT already in DimClub (external clubs)",
                "    ExistingNames = Ligue1Clubs[ClubName],",
                "    ExternalNamesOnly = Table.SelectRows(DistinctNames, each not List.Contains(ExistingNames, [ClubName])),",
                "",
                "    // 4. Build external rows: same columns as Ligue1Clubs, with External = true and nulls elsewhere",
                "    NumLigue1 = Table.RowCount(Ligue1Clubs),",
                "    ExternalWithKey = Table.AddIndexColumn(ExternalNamesOnly, \"ClubKey\", NumLigue1, 1, Int64.Type),",
                "    ExternalWithFlag = Table.AddColumn(ExternalWithKey, \"External\", each true, type logical),",
                "    AddNulls = Table.AddColumn(Table.AddColumn(Table.AddColumn(Table.AddColumn(Table.AddColumn(Table.AddColumn(Table.AddColumn(Table.AddColumn(Table.AddColumn(ExternalWithFlag, \"club_id\", each null), \"city\", each null), \"stadium\", each null), \"capacity\", each null), \"founded\", each null), \"president\", each null), \"coach\", each null), \"budget_ME\", each null), \"colors\", each null),",
                "    ExternalReordered = Table.ReorderColumns(AddNulls, {\"ClubKey\", \"club_id\", \"ClubName\", \"city\", \"stadium\", \"capacity\", \"founded\", \"president\", \"coach\", \"budget_ME\", \"colors\", \"External\"}),",
                "",
                "    // 5. Append external clubs to Ligue 1 clubs",
                "    Final = Table.Combine({Ligue1Clubs, ExternalReordered}),",
                "    #\"Requêtes fusionnées\" = Table.NestedJoin(Final, {\"ClubName\"}, club_logos, {\"club_name\"}, \"club_logos\", JoinKind.LeftOuter),",
                "    #\"club_logos développé\" = Table.ExpandTableColumn(#\"Requêtes fusionnées\", \"club_logos\", {\"logo_url\"}, {\"club_logos.logo_url\"}),",
                "    #\"Colonnes renommées\" = Table.RenameColumns(#\"club_logos développé\",{{\"club_logos.logo_url\", \"Club_URL\"}}),",
                "    #\"Type modifié\" = Table.TransformColumnTypes(#\"Colonnes renommées\",{{\"Club_URL\", type text}})",
                "in",
                "    #\"Type modifié\""
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Points/Match",
            "expression": "SUM(FactClubMatch[Points])/COUNT(DimMatch[MatchKey])",
            "formatString": "0",
            "lineageTag": "4730c41a-0fa8-4cdb-a5c2-a09a1aac2aa2"
          },
          {
            "name": "Goals Difference",
            "expression": "SUM(FactClubMatch[GoalsFor])-SUM(FactClubMatch[GoalsAgainst])",
            "formatString": "0",
            "lineageTag": "e76d755d-a20f-404d-958d-5e55d7f4efd0"
          },
          {
            "name": "Win Rate",
            "expression": [
              "",
              "DIVIDE(",
              "    CALCULATE(",
              "        COUNTROWS('FactClubMatch'),",
              "        'FactClubMatch'[Result] = \"W\"",
              "    ),",
              "    COUNT(DimMatch[Matchday])",
              ")",
              ""
            ],
            "lineageTag": "e07933a8-de47-48eb-a678-3aa6241dd93c",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Matches Played",
            "expression": "COUNTROWS(FactClubMatch)",
            "formatString": "0",
            "lineageTag": "bde754fb-3bb0-4e8b-9d1d-ef0c9ee9394b"
          },
          {
            "name": "Goals For",
            "expression": "SUM(FactClubMatch[GoalsFor])",
            "formatString": "0",
            "lineageTag": "9db05d30-1a3a-4d73-bd24-5f3d5917cf06"
          },
          {
            "name": "Goals Against",
            "expression": "SUM(FactClubMatch[GoalsAgainst])",
            "formatString": "0",
            "lineageTag": "b4194947-fef3-4a68-9726-d046b5dc7e47"
          },
          {
            "name": "Goals For per Match",
            "expression": "DIVIDE([Goals For], [Matches Played], BLANK())",
            "lineageTag": "1aff75d6-87e5-466b-b9a5-c93920a38882",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Goals Against per Match",
            "expression": "DIVIDE([Goals Against], [Matches Played], BLANK())",
            "lineageTag": "c9d8c2c7-ae96-49d8-979e-5d05dca42f19",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ]
          },
          {
            "name": "Logo Club HTML",
            "expression": [
              "",
              "VAR ClubKey = SELECTEDVALUE( FactPlayerSeason[ClubKey] )",
              "VAR UrlLogo = LOOKUPVALUE( DimClub[Club_URL], DimClub[ClubKey], ClubKey )",
              "RETURN",
              "IF(",
              "    NOT ISBLANK(UrlLogo),",
              "    \"<div style='display:flex; align-items:center; height:100%;'>",
              "        <img src='\" & UrlLogo & \"' alt='Logo' style='max-width:150px; height:auto;' />",
              "     </div>\",",
              "    \"\"",
              ")"
            ],
            "lineageTag": "5deeb4d0-5930-48be-b3e9-8214122f53fd"
          }
        ],
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
