              "        <path d='M8 12l2 2 4-4' stroke-linecap='round' stroke-linejoin='round'/>",
              "      </svg>",
              "      <div class='player-name'>\" & vAssisterNameDisplay & \"</div>",
              "      <div class='player-stat'>\" & vAssisterAssistsFmt & \"</div>",
              "      <div class='player-label'>Assists</div>",
              "    </div>",
              "  </div>",
              "</div>",
              "\""
