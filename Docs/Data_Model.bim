                "    #\"En-têtes promus\" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    #\"Type modifié\" = Table.TransformColumnTypes(#\"En-têtes promus\",{{\"club\", type text}, {\"matchday\", Int64.Type}, {\"date\", type text}, {\"opponent\", type text}, {\"attendance\", Int64.Type}, {\"stadium_capacity\", Int64.Type}, {\"fill_rate\", Int64.Type}, {\"weather\", type text}, {\"temperature_c\", Int64.Type}}),",
                "    #\"Espaces supprimés\" = Table.TransformColumns(#\"Type modifié\",{{\"club\", Text.Trim, type text}, {\"date\", Text.Trim, type text}, {\"opponent\", Text.Trim, type text}, {\"weather\", Text.Trim, type text}}),",
                "    #\"Personnalisée ajoutée\" = Table.AddColumn(#\"Espaces supprimés\", \"Personnalisé\", each let",
                "  raw = Text.Trim(Text.From([date])),",
                "  tryIso = try Date.FromText(raw) otherwise null,",
                "  trySlash = if tryIso = null then try Date.FromText(Text.Replace(raw, \"/\", \"-\")) otherwise tryIso else tryIso,",
                "  tryDayMonth = if trySlash = null then try Date.From(DateTime.FromText(raw)) otherwise trySlash else trySlash,",
                "  tryDdMmYyyy = if tryDayMonth = null and Text.Contains(raw, \"/\") then",
                "    let",
                "      parts = Text.Split(raw, \"/\"),",
                "      day = Number.FromText(parts{0}),",
                "      month = Number.FromText(parts{1}),",
                "      year = Number.FromText(parts{2})",
                "    in",
                "      #date(year, month, day)",
                "    else tryDayMonth",
                "in tryDdMmYyyy),",
                "    #\"Colonnes permutées\" = Table.ReorderColumns(#\"Personnalisée ajoutée\",{\"club\", \"matchday\", \"date\", \"Personnalisé\", \"opponent\", \"attendance\", \"stadium_capacity\", \"fill_rate\", \"weather\", \"temperature_c\"}),",
                "    #\"Colonnes supprimées\" = Table.RemoveColumns(#\"Colonnes permutées\",{\"date\"}),",
                "    #\"Colonnes renommées\" = Table.RenameColumns(#\"Colonnes supprimées\",{{\"Personnalisé\", \"date\"}}),",
                "    #\"Personnalisée ajoutée1\" = Table.AddColumn(#\"Colonnes renommées\", \"FillRatePct\", each [fill_rate] / 10),",
                "    #\"Colonnes permutées1\" = Table.ReorderColumns(#\"Personnalisée ajoutée1\",{\"club\", \"matchday\", \"date\", \"opponent\", \"attendance\", \"stadium_capacity\", \"fill_rate\", \"FillRatePct\", \"weather\", \"temperature_c\"}),",
                "    #\"Colonnes supprimées1\" = Table.RemoveColumns(#\"Colonnes permutées1\",{\"fill_rate\"}),",
                "    #\"Colonnes renommées1\" = Table.RenameColumns(#\"Colonnes supprimées1\",{{\"FillRatePct\", \"fill_rate\"}}),",
                "    #\"Type modifié1\" = Table.TransformColumnTypes(#\"Colonnes renommées1\",{{\"fill_rate\", type number}})",
                "in",
                "    #\"Type modifié1\""
              ]
            }
          }
