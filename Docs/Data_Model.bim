            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Staging_PlayerStats,",
                "    #\"Requêtes fusionnées\" = Table.NestedJoin(Source, {\"club\"}, DimClub, {\"ClubName\"}, \"DimClub\", JoinKind.LeftOuter),",
                "    #\"DimClub développé\" = Table.ExpandTableColumn(#\"Requêtes fusionnées\", \"DimClub\", {\"ClubKey\"}, {\"DimClub.ClubKey\"}),",
                "    #\"Colonnes renommées\" = Table.RenameColumns(#\"DimClub développé\",{{\"DimClub.ClubKey\", \"ClubKey\"}}),",
                "    #\"Requêtes fusionnées1\" = Table.NestedJoin(#\"Colonnes renommées\", {\"player_id\"}, DimPlayer, {\"PlayerId\"}, \"DimPlayer\", JoinKind.LeftOuter),",
                "    #\"DimPlayer développé\" = Table.ExpandTableColumn(#\"Requêtes fusionnées1\", \"DimPlayer\", {\"PlayerKey\"}, {\"DimPlayer.PlayerKey\"}),",
                "    #\"Colonnes renommées1\" = Table.RenameColumns(#\"DimPlayer développé\",{{\"DimPlayer.PlayerKey\", \"PlayerKey\"}}),",
                "    #\"Personnalisée ajoutée\" = Table.AddColumn(#\"Colonnes renommées1\", \"MatchesMissed\", each 38 - [matches_played]),",
                "    #\"Colonnes permutées\" = Table.ReorderColumns(#\"Personnalisée ajoutée\",{\"PlayerKey\", \"player_id\", \"ClubKey\", \"full_name\", \"club\", \"position\", \"matches_played\", \"starts\", \"goals\", \"minutes_played\", \"assists\", \"yellow_cards\", \"red_cards\", \"shots\", \"shots_on_target\", \"clean_sheets\", \"saves\", \"successful_dribbles\", \"interceptions\", \"successful_tackles\", \"MatchesMissed\"}),",
                "    #\"Colonnes supprimées\" = Table.RemoveColumns(#\"Colonnes permutées\",{\"player_id\", \"full_name\", \"club\", \"position\"}),",
                "    #\"Colonnes permutées1\" = Table.ReorderColumns(#\"Colonnes supprimées\",{\"PlayerKey\", \"ClubKey\", \"goals\", \"matches_played\", \"starts\", \"minutes_played\", \"assists\", \"yellow_cards\", \"red_cards\", \"shots\", \"shots_on_target\", \"clean_sheets\", \"saves\", \"successful_dribbles\", \"interceptions\", \"successful_tackles\", \"MatchesMissed\"}),",
                "    #\"Colonnes renommées2\" = Table.RenameColumns(#\"Colonnes permutées1\",{{\"goals\", \"Goals\"}}),",
                "    #\"Colonnes permutées2\" = Table.ReorderColumns(#\"Colonnes renommées2\",{\"PlayerKey\", \"ClubKey\", \"Goals\", \"assists\", \"matches_played\", \"starts\", \"minutes_played\", \"yellow_cards\", \"red_cards\", \"shots\", \"shots_on_target\", \"clean_sheets\", \"saves\", \"successful_dribbles\", \"interceptions\", \"successful_tackles\", \"MatchesMissed\"}),",
                "    #\"Colonnes renommées3\" = Table.RenameColumns(#\"Colonnes permutées2\",{{\"assists\", \"Assists\"}, {\"minutes_played\", \"MinutesPlayed\"}}),",
                "    #\"Colonnes permutées3\" = Table.ReorderColumns(#\"Colonnes renommées3\",{\"PlayerKey\", \"ClubKey\", \"Goals\", \"Assists\", \"MinutesPlayed\", \"matches_played\", \"starts\", \"yellow_cards\", \"red_cards\", \"shots\", \"shots_on_target\", \"clean_sheets\", \"saves\", \"successful_dribbles\", \"interceptions\", \"successful_tackles\", \"MatchesMissed\"}),",
                "    #\"Colonnes renommées4\" = Table.RenameColumns(#\"Colonnes permutées3\",{{\"matches_played\", \"MatchesPlayed\"}}),",
                "    #\"Colonnes permutées4\" = Table.ReorderColumns(#\"Colonnes renommées4\",{\"PlayerKey\", \"ClubKey\", \"Goals\", \"Assists\", \"MinutesPlayed\", \"MatchesPlayed\", \"MatchesMissed\", \"starts\", \"yellow_cards\", \"red_cards\", \"shots\", \"shots_on_target\", \"clean_sheets\", \"saves\", \"successful_dribbles\", \"interceptions\", \"successful_tackles\"}),",
                "    #\"Colonnes renommées5\" = Table.RenameColumns(#\"Colonnes permutées4\",{{\"starts\", \"Starts\"}, {\"yellow_cards\", \"YellowCards\"}, {\"red_cards\", \"RedCards\"}, {\"shots\", \"Shots\"}, {\"shots_on_target\", \"ShotsOnTarget\"}, {\"clean_sheets\", \"CleanSheets\"}, {\"saves\", \"Saves\"}, {\"successful_dribbles\", \"SuccessfulDribbles\"}, {\"interceptions\", \"Interceptions\"}, {\"successful_tackles\", \"SuccessfulTackles\"}})",
                "in",
