{
  "name": "Arena (fond arène) — clair",
  "dataColors": [
    "#0066CC",
    "#E65C00",
    "#007BFF",
    "#FF6600",
    "#00A3E0",
    "#FFB347",
    "#5C9EFF",
    "#FFCC99"
  ],
  "firstLevelElements": "#1a1a1a",
  "secondLevelElements": "#404040",
  "thirdLevelElements": "#404040",
  "fourthLevelElements": "#808080",
  "background": "#FFFFFF",
  "secondaryBackground": "#E8F4FC",
  "tableAccent": "#0066CC",
  "good": "#1AAB40",
  "neutral": "#FFC107",
  "bad": "#D64554",
  "maximum": "#0066CC",
  "center": "#FFC107",
  "minimum": "#E65C00",
  "null": "#808080",
  "textClasses": {
    "callout": {
      "fontSize": 45,
      "fontFace": "Segoe UI",
      "color": "#1a1a1a"
    },
    "title": {
      "fontSize": 18,
      "fontFace": "Segoe UI Semibold",
      "color": "#1a1a1a"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#1a1a1a"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#404040"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [{
          "show": true,
          "color": { "solid": { "color": "#FFFFFF" } },
          "transparency": 43
        }],
        "title": [{
          "show": true,
          "fontColor": { "solid": { "color": "#1a1a1a" } },
          "fontSize": 12,
          "fontFamily": "Segoe UI"
        }],
        "border": [{
          "show": true,
          "color": { "solid": { "color": "#E0E0E0" } },
          "radius": 4,
          "borderWidth": 1
        }],
        "categoryAxis": [{
          "labelColor": { "solid": { "color": "#1a1a1a" } },
          "gridLineColor": { "solid": { "color": "#404040" } }
        }],
        "valueAxis": [{
          "labelColor": { "solid": { "color": "#1a1a1a" } },
          "gridLineColor": { "solid": { "color": "#404040" } }
        }],
        "legend": [{
          "labelColor": { "solid": { "color": "#1a1a1a" } }
        }],
        "visualTooltip": [{
          "background": { "solid": { "color": "#FFFFFF" } },
          "fontColor": { "solid": { "color": "#1a1a1a" } },
          "titleFontColor": { "solid": { "color": "#1a1a1a" } }
        }]
      }
    },
    "card": {
      "*": {
        "background": [{ "show": true, "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 43 }],
        "border": [{ "show": true, "color": { "solid": { "color": "#E0E0E0" } }, "radius": 4, "borderWidth": 1 }],
        "categoryLabel": [{ "fontColor": { "solid": { "color": "#404040" } } }],
        "callout": [{ "fontColor": { "solid": { "color": "#1a1a1a" } } }]
      }
    },
    "kpi": {
      "*": {
        "background": [{ "show": true, "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 43 }],
        "border": [{ "show": true, "color": { "solid": { "color": "#E0E0E0" } }, "radius": 4, "borderWidth": 1 }],
        "indicator": [{ "fontColor": { "solid": { "color": "#1a1a1a" } } }],
        "goal": [{ "fontColor": { "solid": { "color": "#404040" } } }],
        "labels": [{ "fontColor": { "solid": { "color": "#1a1a1a" } } }]
      }
    },
    "tableEx": {
      "*": {
        "background": [{ "show": true, "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 43 }],
        "border": [{ "show": true, "color": { "solid": { "color": "#E0E0E0" } }, "radius": 4, "borderWidth": 1 }],
        "grid": [{ "gridVerticalColor": { "solid": { "color": "#404040" } }, "gridHorizontalColor": { "solid": { "color": "#404040" } }, "outlineColor": { "solid": { "color": "#404040" } } }],
        "columnHeaders": [{ "fontColor": { "solid": { "color": "#1a1a1a" } }, "backColor": { "solid": { "color": "#F3F2F1" } } }],
        "values": [{ "fontColorPrimary": { "solid": { "color": "#1a1a1a" } }, "backColorPrimary": { "solid": { "color": "#FFFFFF" } } }],
        "total": [{ "fontColor": { "solid": { "color": "#1a1a1a" } }, "backColor": { "solid": { "color": "#E0E0E0" } } }]
      }
    },
    "pivotTable": {
      "*": {
        "background": [{ "show": true, "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 43 }],
        "border": [{ "show": true, "color": { "solid": { "color": "#E0E0E0" } }, "radius": 4, "borderWidth": 1 }],
        "grid": [{ "gridVerticalColor": { "solid": { "color": "#404040" } }, "gridHorizontalColor": { "solid": { "color": "#404040" } }, "outlineColor": { "solid": { "color": "#404040" } } }],
        "columnHeaders": [{ "fontColor": { "solid": { "color": "#1a1a1a" } }, "backColor": { "solid": { "color": "#F3F2F1" } } }],
        "values": [{ "fontColorPrimary": { "solid": { "color": "#1a1a1a" } }, "backColorPrimary": { "solid": { "color": "#FFFFFF" } } }],
        "total": [{ "fontColor": { "solid": { "color": "#1a1a1a" } }, "backColor": { "solid": { "color": "#E0E0E0" } } }]
      }
    },
    "pageNavigator": {
      "*": {
        "border": [{ "show": false }],
        "title": [{ "show": false }],
        "visualHeader": [{ "show": false }],
        "outline": [
          { "show": true },
          { "$id": "default", "transparency": 0, "lineColor": { "solid": { "color": "#E0E0E0" } }, "weight": 1 },
          { "$id": "hover", "transparency": 0, "lineColor": { "solid": { "color": "#0066CC" } }, "weight": 2 },
          { "$id": "press", "transparency": 0, "lineColor": { "solid": { "color": "#0066CC" } }, "weight": 2 },
          { "$id": "selected", "transparency": 0, "lineColor": { "solid": { "color": "#0066CC" } }, "weight": 2 },
          { "$id": "disabled", "transparency": 0, "lineColor": { "solid": { "color": "#808080" } }, "weight": 1 }
        ],
        "fill": [
          { "show": true },
          { "$id": "default", "transparency": 0, "fillColor": { "solid": { "color": "#F3F2F1" } } },
          { "$id": "hover", "transparency": 0, "fillColor": { "solid": { "color": "#E0E0E0" } } },
          { "$id": "press", "transparency": 0, "fillColor": { "solid": { "color": "#E0E0E0" } } },
          { "$id": "selected", "transparency": 0, "fillColor": { "solid": { "color": "#FFFFFF" } } },
          { "$id": "disabled", "transparency": 0, "fillColor": { "solid": { "color": "#F3F2F1" } } }
        ],
        "text": [
          { "show": true },
          { "$id": "default", "fontFamily": "Segoe UI", "fontSize": 10, "fontColor": { "solid": { "color": "#1a1a1a" } }, "horizontalAlignment": "center", "verticalAlignment": "middle" },
          { "$id": "hover", "fontSize": 10, "fontColor": { "solid": { "color": "#1a1a1a" } }, "fontFamily": "Segoe UI" },
          { "$id": "press", "fontSize": 10, "fontColor": { "solid": { "color": "#1a1a1a" } }, "fontFamily": "Segoe UI" },
          { "$id": "selected", "fontSize": 10, "fontColor": { "solid": { "color": "#0066CC" } }, "fontFamily": "Segoe UI Semibold" },
          { "$id": "disabled", "fontSize": 10, "fontColor": { "solid": { "color": "#808080" } }, "fontFamily": "Segoe UI" }
        ],
        "shape": [{ "$id": "default", "roundEdge": 4, "tileShape": "rectangleRounded" }]
      }
    }
  }
}
